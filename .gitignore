# Dependencies
node_modules/

# Production
dist/
src-tauri/target/

# Tauri auto-generated schemas (regenerated on every build)
src-tauri/gen/schemas/
scripts/*

# Documentation: scratch docs stay untracked, but the modular-architecture
# plan and the frozen plugin-system spec are versioned with the code that
# implements them.
docs/*
!docs/MODULAR_AUDIT.md
!docs/plugins/

# Drops folder (local mining tool) - only root level, not src/components/drops
/drops/

# Plugin source trees (developed here, shipped as signed artifacts through the
# plugins index - not bundled with or pushed to the app repo). Root-level only,
# so src/components/drops and docs/plugins are unaffected.
/plugins/

# Streamlink portable (for development - bundled in production releases)
/streamlink/

# Update artifacts
update_streamnook.bat
StreamNook_new.exe

# Release artifacts (only uploaded to GitHub releases, not committed)
*.7z
checksums.txt
StreamNook.exe

# Documentation
RELEASE.md

# Environment variables
.env
.env.local
.env.*.local

# Supabase local CLI scaffolding (migrations, edge functions, link state) -
# backend lives with the Supabase project, not the desktop app repo.
supabase/

# System
.DS_Store
Thumbs.db
